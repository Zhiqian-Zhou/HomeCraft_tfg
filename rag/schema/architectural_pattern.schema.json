{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/architectural_pattern.schema.json",
  "title": "ArchitecturalPattern",
  "description": "RAG-C entry: an Alexander pattern (Pattern Language or Nature of Order property) operationalised for HomeCraft.",
  "type": "object",
  "required": ["id", "name", "source_work", "paraphrase", "canonical_reference"],
  "additionalProperties": false,
  "properties": {
    "id":   { "type": "string", "pattern": "^[a-z][a-z0-9_-]+$" },
    "name": { "type": "string" },
    "source_work": {
      "type": "string",
      "enum": [
        "A Pattern Language",
        "Notes on the Synthesis of Form",
        "The Nature of Order"
      ]
    },
    "paraphrase":      { "type": "string", "minLength": 20 },
    "verified_against_corpus": { "type": "boolean" },
    "canonical_reference": {
      "type": "object",
      "required": ["pages", "edition"],
      "properties": {
        "pages":   { "type": "string" },
        "edition": { "type": "string" },
        "isbn":    { "type": "string" }
      }
    },
    "geometric_operationalisation": {
      "type": "object",
      "properties": {
        "metric_name": { "type": "string" },
        "python_path": { "type": "string" },
        "expected_range": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } }
      }
    },
    "skills_embodying": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
