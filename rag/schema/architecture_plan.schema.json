{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/architecture_plan.schema.json",
  "title": "ArchitecturePlan",
  "description": "Output of the architecture_planner (Stage 1c in v3, DETERMINISTIC, no LLM). Envelope ops ONLY: walls, floors, ceilings, roof. Each op carries room_id + envelope_role for downstream connector_validator lookups.",
  "type": "object",
  "required": ["schema_version", "ops", "materials_used"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "ops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "envelope_role"],
        "additionalProperties": true,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["fill", "fill_hollow", "outline", "rect", "stairs", "place"],
            "description": "Envelope ops + 'place' for fixed light fixtures (lanterns) that the deterministic planner installs to guarantee a minimum light_coverage."
          },
          "envelope_role": {
            "type": "string",
            "enum": ["foundation", "floor_slab", "wall", "shared_wall",
                     "interior_partition", "ceiling", "roof", "parapet",
                     "exterior_stair", "frame"]
          },
          "room_id": {
            "type": ["string", "null"],
            "description": "Which room this op belongs to. null = site-level (foundation, roof)."
          },
          "shared_with": {
            "type": "array",
            "items": { "type": "string" },
            "description": "For party walls: room_ids on the other side of this wall."
          }
        }
      }
    },
    "materials_used": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["block_id"],
        "additionalProperties": false,
        "properties": {
          "block_id": {
            "type": "string",
            "pattern": "^minecraft:[a-z0-9_]+(?:\\[[^\\]]*\\])?$"
          },
          "palette_slot": { "type": "string", "pattern": "^@[a-z_]+$" },
          "envelope_roles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "op_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "generated_by": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deterministic": { "type": "boolean", "const": true },
        "module": { "type": "string" },
        "version": { "type": "string" }
      }
    }
  }
}
