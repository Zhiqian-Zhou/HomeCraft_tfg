{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/connector_plan.schema.json",
  "title": "ConnectorPlan",
  "description": "Output of the connector_planner (Stage 1d in v3). LLM proposes; deterministic validator clamps y, snaps to wall, computes facing, carves openings. Each item carries proposal + validated + warnings + carve_ops for audit.",
  "type": "object",
  "required": ["schema_version", "doors", "windows", "staircases"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "doors": {
      "type": "array",
      "items": { "$ref": "#/$defs/door_item" }
    },
    "windows": {
      "type": "array",
      "items": { "$ref": "#/$defs/window_item" }
    },
    "staircases": {
      "type": "array",
      "items": { "$ref": "#/$defs/staircase_item" }
    },
    "dropped": {
      "type": "array",
      "description": "Items the validator could not repair and dropped.",
      "items": {
        "type": "object",
        "required": ["id", "kind", "drop_code"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string", "enum": ["door", "window", "staircase"] },
          "drop_code": {
            "type": "string",
            "enum": ["room_not_found", "outside_envelope", "no_valid_wall",
                     "overlap_with_existing_connector", "staircase_no_floor_clearance"]
          },
          "details": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "passthrough": { "type": "integer", "minimum": 0 },
        "auto_fixed": { "type": "integer", "minimum": 0 },
        "dropped": { "type": "integer", "minimum": 0 },
        "warning_codes": { "type": "object" }
      }
    }
  },
  "$defs": {
    "warning": {
      "type": "object",
      "required": ["code"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["clamped_axis", "aligned_to_wall", "facing_normalized",
                   "between_reordered", "floor_offset_applied",
                   "block_key_resolved", "duplicate_id_renamed",
                   "carved_opening"]
        },
        "before": {},
        "after": {},
        "message": { "type": "string" }
      }
    },
    "carve_op": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["fill", "place"]
        }
      }
    },
    "door_item": {
      "type": "object",
      "required": ["id", "validated"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "proposal": {
          "type": "object",
          "description": "Original LLM proposal (may be malformed). Kept for audit."
        },
        "validated": {
          "type": "object",
          "required": ["between", "at", "facing"],
          "additionalProperties": false,
          "properties": {
            "between": {
              "type": "array", "minItems": 2, "maxItems": 2,
              "items": { "type": "string" }
            },
            "at": {
              "type": "array", "minItems": 3, "maxItems": 3,
              "items": { "type": "integer" }
            },
            "facing": {
              "type": "string",
              "enum": ["n", "s", "e", "w"]
            },
            "block_key": { "type": "string" }
          }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/warning" }
        },
        "carve_ops": {
          "type": "array",
          "items": { "$ref": "#/$defs/carve_op" }
        }
      }
    },
    "window_item": {
      "type": "object",
      "required": ["id", "validated"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "proposal": { "type": "object" },
        "validated": {
          "type": "object",
          "required": ["in_room", "wall", "aabb"],
          "properties": {
            "in_room": { "type": "string" },
            "wall": { "type": "string", "enum": ["n", "s", "e", "w"] },
            "aabb": {
              "type": "array", "minItems": 6, "maxItems": 6,
              "items": { "type": "integer" }
            },
            "block_key": { "type": "string" }
          }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/warning" }
        },
        "carve_ops": {
          "type": "array",
          "items": { "$ref": "#/$defs/carve_op" }
        }
      }
    },
    "staircase_item": {
      "type": "object",
      "required": ["id", "validated"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "proposal": { "type": "object" },
        "validated": {
          "type": "object",
          "required": ["aabb", "from_floor", "to_floor"],
          "properties": {
            "from_floor": { "type": "integer", "minimum": 0 },
            "to_floor": { "type": "integer", "minimum": 0 },
            "aabb": {
              "type": "array", "minItems": 6, "maxItems": 6,
              "items": { "type": "integer" }
            },
            "shape": { "type": "string" },
            "block_key": { "type": "string" }
          }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/warning" }
        },
        "carve_ops": {
          "type": "array",
          "items": { "$ref": "#/$defs/carve_op" }
        }
      }
    }
  }
}
