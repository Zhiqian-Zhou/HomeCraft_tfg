{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/floor_plan.schema.json",
  "title": "FloorPlan",
  "description": "Output of the v4 floor_planner (one instance per floor, run in parallel). Carries the room list, intra-floor adjacency graph, and footprint reservations for stairs/shafts/chimneys propagated down from space_plan_v4.vertical_connections.",
  "type": "object",
  "required": ["schema_version", "floor_index", "layout_skill_id_used", "rooms", "adjacency_graph"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "v4" },
    "floor_index": { "type": "integer", "minimum": 0 },
    "layout_skill_id_used": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]+$",
      "description": "ID of the floor_layout skill instantiated by this plan. Must equal space_plan_v4.floor_layout_id_per_floor[floor_index]."
    },
    "expanded_description": {
      "type": "string",
      "minLength": 50,
      "maxLength": 2000
    },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role", "floor", "aabb"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(?!outside$)[a-z][a-z0-9_-]*$"
          },
          "role": {
            "type": "string",
            "enum": ["kitchen", "bedroom", "bathroom", "living_room", "dining_room",
                     "library", "study", "hallway", "entry_hall", "basement",
                     "attic", "courtyard_indoor", "chapel", "throne_room",
                     "great_hall", "music_room", "nursery", "pantry"]
          },
          "floor": { "type": "integer", "minimum": 0 },
          "aabb": {
            "type": "array", "minItems": 6, "maxItems": 6,
            "items": { "type": "integer" }
          },
          "note": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "adjacency_graph": {
      "type": "array",
      "description": "Intra-floor room graph. 'outside' is a reserved sentinel allowed only when this floor has an entry_point in space_plan_v4.",
      "items": {
        "type": "object",
        "required": ["from_room", "to_room", "kind"],
        "additionalProperties": false,
        "properties": {
          "from_room": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "to_room":   { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "kind": {
            "type": "string",
            "enum": ["door", "opening", "none"],
            "description": "door=place door block; opening=archway carve; none=considered+rejected (audit trail)."
          }
        }
      }
    },
    "reserved_footprints": {
      "type": "array",
      "description": "XZ rectangles this floor must keep clear (stair landings, shafts, chimneys). Propagated from space_plan_v4.vertical_connections; y-extent is implicit from floors[floor_index].",
      "items": {
        "type": "object",
        "required": ["x0", "z0", "x1", "z1", "kind"],
        "additionalProperties": false,
        "properties": {
          "x0": { "type": "integer" },
          "z0": { "type": "integer" },
          "x1": { "type": "integer" },
          "z1": { "type": "integer" },
          "kind": { "type": "string", "enum": ["stair", "shaft", "chimney"] },
          "template_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]+$",
            "description": "Optional link back to space_plan_v4.vertical_connections[].template_id (or connector_templates_used[].template_id for chimneys)."
          }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
