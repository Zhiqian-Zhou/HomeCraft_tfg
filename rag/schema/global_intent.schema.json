{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/global_intent.schema.json",
  "title": "GlobalIntent",
  "description": "Output of the global_designer (Stage 1a in v3). Global decisions: style, building envelope, floors, height intent, Alexander rationale. Downstream space_planner consumes this to lay rooms.",
  "type": "object",
  "required": [
    "schema_version",
    "prompt",
    "category",
    "style",
    "site_aabb",
    "building_aabb",
    "floors",
    "height_intent",
    "alexander_rationale"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "prompt": { "type": "string", "minLength": 1 },
    "expanded_prompt_ref": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["residential", "castle", "tower", "temple", "shop", "tavern",
               "barn", "windmill", "lighthouse", "monument", "other"]
    },
    "style": {
      "type": "string",
      "enum": ["medieval", "fantasy", "gothic", "renaissance", "modern", "minimalist",
               "japanese", "chinese", "mediterranean", "rustic"]
    },
    "exemplars_used": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Building IDs from rag/reference_buildings/processed/ used as exemplars."
    },
    "site_aabb": {
      "type": "array", "minItems": 6, "maxItems": 6,
      "items": { "type": "integer" }
    },
    "building_aabb": {
      "type": "array", "minItems": 6, "maxItems": 6,
      "items": { "type": "integer" }
    },
    "floors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["index", "y0", "y1"],
        "additionalProperties": false,
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "y0": { "type": "integer", "minimum": 0 },
          "y1": { "type": "integer", "minimum": 1 },
          "name": { "type": "string" },
          "role_hint": {
            "type": "string"
          }
        }
      }
    },
    "height_intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "per_floor_height": { "type": "integer", "minimum": 3, "maximum": 12 },
        "roof_style": {
          "type": "string",
          "enum": ["flat", "gable", "hip", "pyramid", "shed", "dome",
                   "pagoda", "conical", "thatched", "mansard", "gambrel",
                   "other"]
        },
        "roof_pitch": { "type": "integer", "minimum": 0, "maximum": 5 },
        "has_basement": { "type": "boolean" },
        "tower_axis": {
          "type": "string",
          "enum": ["none", "central", "corner"]
        }
      }
    },
    "alexander_rationale": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern_id", "rationale"],
        "additionalProperties": false,
        "properties": {
          "pattern_id": { "type": "string" },
          "applied_to": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["site", "building_envelope", "floors", "roof", "orientation"]
            }
          },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "atmosphere": { "type": "string" },
    "constraints": { "type": "object" },
    "notes": { "type": "string" }
  }
}
