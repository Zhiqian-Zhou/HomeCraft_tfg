{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/global_intent_v4.schema.json",
  "title": "GlobalIntentV4",
  "description": "Output of the v4 global_designer. Same envelope/floors/height contract as v3, plus a mandatory silhouette_id referencing a skill with skill_category='global_silhouette'. Replaces the v3 'prompt' field with 'expanded_description' to mirror the v4 expander contract.",
  "type": "object",
  "required": [
    "schema_version",
    "expanded_description",
    "category",
    "style",
    "silhouette_id",
    "site_aabb",
    "building_aabb",
    "floors",
    "height_intent",
    "alexander_rationale"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "v4"
    },
    "secondary_masses": {
      "type": "array",
      "description": "OPTIONAL. Secondary architectural masses that rise/extend beyond the main silhouette — ONLY when the prompt describes a large, monumental or compositionally complex building (a cathedral, a fortified castle, a grand palace…). Leave empty/omit for ordinary buildings (a cottage, a shop, a normal house). Each mass must be COHERENT with the requested building (a cathedral → a campanile + a dome; a fortress → corner towers + a keep; a palace → flanking wings or a central dome). The materialiser places them anchored to the main body; you only declare what fits the design.",
      "items": {
        "type": "object",
        "required": [
          "type",
          "position"
        ],
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string",
            "description": "tower | keep | turret | campanile | spire | pinnacle | dome | cupola | wing | annex | pavilion | transept"
          },
          "position": {
            "type": "string",
            "description": "corner-nw | corner-ne | corner-sw | corner-se | center | front | back | left | right | flanking-entrance"
          },
          "size": {
            "type": "string",
            "description": "small | medium | large"
          },
          "rationale": {
            "type": "string",
            "description": "one phrase: why this mass fits the requested building"
          }
        }
      }
    },
    "original_prompt": {
      "type": "string",
      "minLength": 1
    },
    "expanded_description": {
      "type": "string",
      "minLength": 50,
      "maxLength": 2000,
      "description": "Mirror of the v4 expander output (80-200 word paragraph)."
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "description": "Building category. The supplied enum below lists FIRST-CLASS values that the pipeline knows how to specialise (palettes, exterior features, fittings). You MAY use any other free-form value (e.g. 'mansion', 'chapel', 'library', 'observatory') when the prompt clearly asks for something outside the catalogue — downstream stages fall back to safe defaults rather than rejecting the choice. Treat the enum as recommendations, not restrictions.",
      "examples": [
        "residential",
        "castle",
        "tower",
        "temple",
        "shop",
        "tavern",
        "barn",
        "windmill",
        "lighthouse",
        "monument",
        "mansion",
        "chapel",
        "library",
        "market",
        "observatory",
        "other"
      ]
    },
    "style": {
      "type": "string",
      "minLength": 1,
      "description": "Architectural style. The supplied enum below lists FIRST-CLASS values that the pipeline has bespoke palettes for. You MAY use any other free-form value (e.g. 'victorian', 'art-deco', 'brutalist', 'byzantine', 'baroque', 'colonial', 'neoclassical', 'tudor') when the prompt asks for something outside the catalogue — downstream stages fall back to a sensible default palette rather than rejecting the choice. Treat the enum as recommendations, not restrictions.",
      "examples": [
        "medieval",
        "fantasy",
        "gothic",
        "renaissance",
        "modern",
        "minimalist",
        "japanese",
        "chinese",
        "mediterranean",
        "rustic",
        "victorian",
        "art-deco",
        "brutalist",
        "byzantine",
        "baroque",
        "colonial",
        "neoclassical",
        "tudor"
      ]
    },
    "silhouette_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]+$",
      "description": "ID of a skill with skill_category='global_silhouette' (e.g. 'gable-cottage-silhouette')."
    },
    "silhouette_parameters": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional overrides for the silhouette skill's documented parameters (e.g. concrete value picked from a range)."
    },
    "silhouette_rationale": {
      "type": "string",
      "minLength": 1
    },
    "exemplars_used": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Reference-building IDs used as exemplars (provenance/audit)."
    },
    "site_aabb": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "integer"
      }
    },
    "building_aabb": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "integer"
      }
    },
    "floors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "index",
          "y0",
          "y1"
        ],
        "additionalProperties": false,
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "y0": {
            "type": "integer",
            "minimum": 0
          },
          "y1": {
            "type": "integer",
            "minimum": 1
          },
          "name": {
            "type": "string"
          },
          "role_hint": {
            "type": "string"
          }
        }
      }
    },
    "height_intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "per_floor_height": {
          "type": "integer",
          "minimum": 3,
          "maximum": 12
        },
        "roof_style": {
          "type": "string",
          "enum": [
            "a-frame",
            "asian",
            "barn",
            "barrel",
            "barrel-vault",
            "battlement",
            "battlements",
            "butterfly",
            "chinese-hip",
            "chinese-pagoda",
            "clerestory",
            "cone",
            "conical",
            "crenellated",
            "cross-gable",
            "dome",
            "double-pagoda",
            "dutch-gable",
            "flat",
            "front-gable",
            "gable",
            "gable-shallow",
            "gable-steep",
            "gambrel",
            "half-hip",
            "helm",
            "hip",
            "hip-steep",
            "irimoya",
            "japanese-hip",
            "jerkinhead",
            "lean-to",
            "mansard",
            "monitor",
            "needle",
            "north-light",
            "onion",
            "onion-dome",
            "pagoda",
            "parapet",
            "pavilion",
            "pyramid",
            "pyramidal",
            "rhenish-helm",
            "saltbox",
            "sawtooth",
            "shed",
            "side-gable",
            "skillion",
            "spire",
            "stepped-dome",
            "stepped-parapet",
            "temple",
            "tented",
            "thatched",
            "tiered",
            "upturned",
            "upturned-eave",
            "ziggurat",
            "other"
          ]
        },
        "roof_pitch": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "has_basement": {
          "type": "boolean"
        },
        "tower_axis": {
          "type": "string",
          "enum": [
            "none",
            "central",
            "corner"
          ]
        },
        "roof_features": {
          "type": "array",
          "description": "Modular roof add-ons composed onto the base roof_style (LEGO pieces). 0-4 distinct items.",
          "items": {
            "type": "string",
            "enum": [
              "dormer",
              "chimney",
              "cupola",
              "finial",
              "ridge-cresting",
              "corner-turrets"
            ]
          },
          "maxItems": 4,
          "uniqueItems": true
        }
      }
    },
    "alexander_rationale": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pattern_id",
          "rationale"
        ],
        "additionalProperties": false,
        "properties": {
          "pattern_id": {
            "type": "string"
          },
          "applied_to": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "site",
                "building_envelope",
                "floors",
                "roof",
                "orientation",
                "silhouette"
              ]
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "atmosphere": {
      "type": "string"
    },
    "constraints": {
      "type": "object"
    },
    "notes": {
      "type": "string"
    },
    "implied_rooms": {
      "type": "array",
      "description": "OPTIONAL. Roles de sala pedidos explícitamente en el prompt (p.ej. ['bedroom','bedroom','bedroom','bedroom','kitchen','kitchen']). Parseado determinista del prompt; se usa para sembrar room_role_hints y para la métrica prompt_adherence.",
      "items": {
        "type": "string"
      }
    }
  }
}
