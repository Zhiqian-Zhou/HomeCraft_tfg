{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/master_plan.schema.json",
  "title": "MasterPlan",
  "description": "Output of the aggregator: concatenated ops in correct order + BOT decomposition, ready for the voxelizer.",
  "type": "object",
  "required": ["id", "style", "site_aabb", "ops", "bot_decomposition"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{2,63}$" },
    "prompt": { "type": "string" },
    "style": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["residential", "castle", "tower", "temple", "shop", "tavern",
               "barn", "windmill", "lighthouse", "monument", "other"]
    },
    "site_aabb": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": { "type": "integer" }
    },
    "ops": {
      "type": "array",
      "items": {
        "$ref": "https://homecraft.tfg/schemas/shape_op.schema.json"
      }
    },
    "bot_decomposition": {
      "type": "object",
      "required": ["building"],
      "properties": {
        "building": {
          "type": "object",
          "required": ["storeys"],
          "properties": {
            "storeys": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "spaces"],
                "properties": {
                  "id": { "type": "string" },
                  "aabb": {
                    "type": "array",
                    "minItems": 6,
                    "maxItems": 6,
                    "items": { "type": "integer" }
                  },
                  "spaces": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id", "function", "aabb"],
                      "properties": {
                        "id": { "type": "string" },
                        "function": { "type": "string" },
                        "aabb": {
                          "type": "array",
                          "minItems": 6,
                          "maxItems": 6,
                          "items": { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "connectors": {
      "description": "Globally planned connectors propagated from the design_intent. Consumed by evaluator metrics (main_entrance, voxel_connectivity, light_on_two_sides). Optional for backward compatibility with master_plans produced before aggregator v2.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "doors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "between", "at", "facing"],
            "properties": {
              "id": { "type": "string" },
              "between": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": { "type": "string" }
              },
              "at": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": { "type": "integer" }
              },
              "facing": {
                "type": "string",
                "enum": ["n", "s", "e", "w", "north", "south", "east", "west"]
              },
              "block_key": { "type": "string" }
            }
          }
        },
        "windows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "in_room", "wall", "aabb"],
            "properties": {
              "id": { "type": "string" },
              "in_room": { "type": "string" },
              "wall": {
                "type": "string",
                "enum": ["n", "s", "e", "w", "north", "south", "east", "west"]
              },
              "aabb": {
                "type": "array",
                "minItems": 6,
                "maxItems": 6,
                "items": { "type": "integer" }
              },
              "block_key": { "type": "string" }
            }
          }
        },
        "staircases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "aabb"],
            "properties": {
              "id": { "type": "string" },
              "from_floor": { "type": "integer", "minimum": 0 },
              "to_floor": { "type": "integer", "minimum": 0 },
              "aabb": {
                "type": "array",
                "minItems": 6,
                "maxItems": 6,
                "items": { "type": "integer" }
              },
              "shape": { "type": "string" },
              "block_key": { "type": "string" }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
