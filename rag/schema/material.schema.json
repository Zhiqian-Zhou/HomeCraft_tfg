{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/material.schema.json",
  "title": "Material",
  "description": "RAG-D entry: a single Minecraft 1.16.5 block with semantic metadata.",
  "type": "object",
  "required": ["id", "block_id", "category", "color"],
  "additionalProperties": false,
  "properties": {
    "id":       { "type": "string", "pattern": "^[a-z][a-z0-9_-]+$" },
    "block_id": { "type": "string", "pattern": "^minecraft:[a-z0-9_]+$" },
    "category": {
      "type": "string",
      "enum": [
        "wood", "stone", "brick", "glass", "metal", "wool", "concrete",
        "terracotta", "plant", "fluid", "light-source", "redstone",
        "decorative", "utility", "furniture", "ground", "other"
      ]
    },
    "color":         { "type": "string" },
    "transparent":   { "type": "boolean" },
    "light_emission":{ "type": "integer", "minimum": 0, "maximum": 15 },
    "is_solid":      { "type": "boolean" },
    "variants": {
      "type": "object",
      "properties": {
        "stairs": { "type": "string" },
        "slab":   { "type": "string" },
        "wall":   { "type": "string" },
        "fence":  { "type": "string" }
      }
    },
    "used_by_styles": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
