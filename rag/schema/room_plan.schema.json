{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/room_plan.schema.json",
  "title": "RoomPlan",
  "description": "Output of a room (or exterior) specialist agent: shape ops that fill one room AABB while respecting connector reservations from the design_intent.",
  "type": "object",
  "required": ["room_id", "role", "aabb", "style", "ops"],
  "additionalProperties": false,
  "properties": {
    "room_id": { "type": "string", "minLength": 1 },
    "role": { "type": "string" },
    "aabb": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": { "type": "integer" }
    },
    "style": {
      "type": "string",
      "enum": ["medieval", "fantasy", "gothic", "renaissance", "modern", "minimalist",
               "japanese", "chinese", "mediterranean", "rustic"]
    },
    "patterns_applied": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skill_chosen": {
      "type": ["string", "null"],
      "description": "id of base skill (if any) the agent built on top of. May be null when the agent used only primitives."
    },
    "ops": {
      "type": "array",
      "items": {
        "$ref": "https://homecraft.tfg/schemas/shape_op.schema.json"
      }
    },
    "notes": { "type": ["string", "null"] }
  }
}
