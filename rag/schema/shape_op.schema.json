{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/shape_op.schema.json",
  "title": "ShapeOp",
  "description": "A single shape operation emitted by a planner agent. The voxelizer maps each op to a pipeline.skills.base.Op (or to a skill invocation). `block` strings accept namespaced 1.16.5 IDs (with optional blockstate suffix) or @key placeholders resolved by Materials.",
  "type": "object",
  "required": ["kind"],
  "oneOf": [
    {
      "title": "skill",
      "type": "object",
      "required": ["kind", "skill_id", "aabb"],
      "properties": {
        "kind": { "const": "skill" },
        "skill_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "aabb": { "$ref": "#/$defs/aabb" },
        "style": { "type": "string" },
        "kwargs": { "type": "object" }
      },
      "additionalProperties": false
    },
    {
      "title": "typology",
      "type": "object",
      "required": ["kind", "name", "aabb"],
      "properties": {
        "kind": { "const": "typology" },
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "aabb": { "$ref": "#/$defs/aabb" },
        "style": { "type": "string" },
        "kwargs": { "type": "object" },
        "envelope_role": { "type": "string" },
        "room_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    {
      "title": "place",
      "type": "object",
      "required": ["kind", "at", "block"],
      "properties": {
        "kind": { "const": "place" },
        "at": { "$ref": "#/$defs/xyz" },
        "block": { "$ref": "#/$defs/block_ref" }
      },
      "additionalProperties": false
    },
    {
      "title": "fill",
      "type": "object",
      "required": ["kind", "aabb", "block"],
      "properties": {
        "kind": { "const": "fill" },
        "aabb": { "$ref": "#/$defs/aabb" },
        "block": { "$ref": "#/$defs/block_ref" }
      },
      "additionalProperties": false
    },
    {
      "title": "fill_hollow",
      "type": "object",
      "required": ["kind", "aabb", "wall"],
      "properties": {
        "kind": { "const": "fill_hollow" },
        "aabb": { "$ref": "#/$defs/aabb" },
        "wall":    { "$ref": "#/$defs/block_ref" },
        "fill":    { "$ref": "#/$defs/block_ref" },
        "floor":   { "$ref": "#/$defs/block_ref" },
        "ceiling": { "$ref": "#/$defs/block_ref" }
      },
      "additionalProperties": false
    },
    {
      "title": "outline",
      "type": "object",
      "required": ["kind", "aabb", "block"],
      "properties": {
        "kind": { "const": "outline" },
        "aabb": { "$ref": "#/$defs/aabb" },
        "block": { "$ref": "#/$defs/block_ref" }
      },
      "additionalProperties": false
    },
    {
      "title": "rect",
      "type": "object",
      "required": ["kind", "aabb", "axis", "level", "block"],
      "properties": {
        "kind": { "const": "rect" },
        "aabb": { "$ref": "#/$defs/aabb" },
        "axis": { "type": "string", "enum": ["x", "y", "z"] },
        "level": { "type": "integer" },
        "block": { "$ref": "#/$defs/block_ref" }
      },
      "additionalProperties": false
    },
    {
      "title": "line",
      "type": "object",
      "required": ["kind", "from", "to", "block"],
      "properties": {
        "kind": { "const": "line" },
        "from": { "$ref": "#/$defs/xyz" },
        "to":   { "$ref": "#/$defs/xyz" },
        "block": { "$ref": "#/$defs/block_ref" }
      },
      "additionalProperties": false
    },
    {
      "title": "cylinder",
      "type": "object",
      "required": ["kind", "cx", "cz", "y0", "radius", "height", "block"],
      "properties": {
        "kind": { "const": "cylinder" },
        "cx": { "type": "integer" },
        "cz": { "type": "integer" },
        "y0": { "type": "integer" },
        "radius": { "type": "integer", "minimum": 1, "maximum": 64 },
        "height": { "type": "integer", "minimum": 1, "maximum": 256 },
        "block": { "$ref": "#/$defs/block_ref" },
        "hollow": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    {
      "title": "stairs",
      "type": "object",
      "required": ["kind", "from", "to", "block"],
      "properties": {
        "kind": { "const": "stairs" },
        "from": { "$ref": "#/$defs/xyz" },
        "to":   { "$ref": "#/$defs/xyz" },
        "block": { "$ref": "#/$defs/block_ref" }
      },
      "additionalProperties": false
    }
  ],
  "$defs": {
    "xyz": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "integer" }
    },
    "aabb": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": { "type": "integer" },
      "description": "[x0,y0,z0,x1,y1,z1] half-open: x in [x0,x1), etc."
    },
    "block_ref": {
      "type": "string",
      "pattern": "^(@[a-z_]+(\\[[a-z0-9_=,]+\\])?|minecraft:[a-z0-9_]+(\\[[a-z0-9_=,]+\\])?)$",
      "description": "Either a @key placeholder (optionally with blockstate, e.g. @door[half=lower,facing=south]) or a namespaced 1.16.5 block id with optional blockstate."
    }
  }
}
