{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/space_plan.schema.json",
  "title": "SpacePlan",
  "description": "Output of the space_planner (Stage 1b in v3). Rooms with AABBs + role + floor, PLUS adjacency_graph declaring which rooms should be connected (with kind=door|opening|none). The graph is consumed by connector_planner to know WHICH connectors to place.",
  "type": "object",
  "required": ["schema_version", "rooms", "adjacency_graph"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role", "floor", "aabb"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(?!outside$)[a-z][a-z0-9_-]*$"
          },
          "role": {
            "type": "string",
            "enum": ["kitchen", "bedroom", "bathroom", "living_room", "dining_room",
                     "library", "study", "hallway", "entry_hall", "basement",
                     "attic", "courtyard_indoor", "chapel", "throne_room",
                     "great_hall", "music_room", "nursery", "pantry"]
          },
          "floor": { "type": "integer", "minimum": 0 },
          "aabb": {
            "type": "array", "minItems": 6, "maxItems": 6,
            "items": { "type": "integer" }
          }
        }
      }
    },
    "adjacency_graph": {
      "type": "array",
      "description": "Edges of the room-graph including 'outside' as a sentinel vertex.",
      "items": {
        "type": "object",
        "required": ["from_room", "to_room", "kind"],
        "additionalProperties": false,
        "properties": {
          "from_room": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "to_room": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "kind": {
            "type": "string",
            "enum": ["door", "opening", "none"],
            "description": "door = place a door block; opening = carve an archway; none = considered and rejected (audit trail)."
          }
        }
      }
    }
  }
}
