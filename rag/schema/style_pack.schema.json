{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homecraft.tfg/schemas/style_pack.schema.json",
  "title": "StylePack",
  "description": "RAG-B entry: a named architectural style's palette, signature elements, and typical ratios. Block IDs are 1.16.5 namespaced.",
  "type": "object",
  "required": ["id", "name", "palette", "ratios"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]+$" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "palette": {
      "type": "object",
      "required": ["primary", "roof", "floor"],
      "additionalProperties": false,
      "properties": {
        "primary":   { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^minecraft:" } },
        "secondary": { "type": "array", "items": { "type": "string", "pattern": "^minecraft:" } },
        "accent":    { "type": "array", "items": { "type": "string", "pattern": "^minecraft:" } },
        "roof":      { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^minecraft:" } },
        "floor":     { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^minecraft:" } },
        "glass":     { "type": "array", "items": { "type": "string", "pattern": "^minecraft:" } },
        "light":     { "type": "array", "items": { "type": "string", "pattern": "^minecraft:" } }
      }
    },
    "signature_elements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ratios": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "story_height": { "type": "integer", "minimum": 2, "maximum": 12 },
        "wall_thickness": { "type": "integer", "minimum": 1, "maximum": 4 },
        "window_width": { "type": "integer", "minimum": 1, "maximum": 8 },
        "roof_pitch": { "type": "number", "minimum": 0, "maximum": 2 }
      }
    },
    "alexander_patterns": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
